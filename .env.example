# Copy to .env for local use. Never commit real secrets.
# Production template: .env.production.example

# App
APP_ENV=local
APP_DEBUG=true
APP_NAME=CineTaste
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security
JWT_SECRET=local-dev-only-change-me-to-a-long-random-string-32chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_ALGORITHM=HS256

# Database
DATABASE_URL=postgresql+asyncpg://cinetaste:cinetaste@localhost:5432/cinetaste

# Redis
REDIS_URL=redis://localhost:6379/0

# Catalog (TMDb)
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# Recommendations
REC_SLATE_SIZE=20
REC_CACHE_TTL_SECONDS=600
REC_MMR_LAMBDA=0.7

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=60

TRUSTED_HOSTS=
