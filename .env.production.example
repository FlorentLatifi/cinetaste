# Copy to .env.production and fill real secrets. Never commit the real file.

APP_ENV=production
APP_DEBUG=false
APP_NAME=CineTaste
API_PREFIX=/api/v1

# Your Vercel (or other) frontend origin(s), comma-separated
CORS_ORIGINS=https://cinetaste.vercel.app

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_ALGORITHM=HS256

POSTGRES_USER=cinetaste
POSTGRES_PASSWORD=
POSTGRES_DB=cinetaste
# DATABASE_URL is usually injected by the host (Railway/Render) — example:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/cinetaste
REDIS_URL=

TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

REC_SLATE_SIZE=20
REC_CACHE_TTL_SECONDS=600
REC_MMR_LAMBDA=0.7

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=60

# Optional: api.yourdomain.com
TRUSTED_HOSTS=

WEB_CONCURRENCY=2
PORT=8000

PUBLIC_APP_URL=https://cinetaste.vercel.app
PASSWORD_RESET_TTL_MINUTES=60

# Recommended in production for real reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true

# Observability — create a Sentry project, paste DSNs (optional but recommended)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# Vercel frontend env (not read by API):
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_RELEASE=
