# Copy to .env.staging and fill secrets. Never commit the real file.
# Used with: docker compose -p cinetaste-staging -f docker-compose.staging.yml --env-file .env.staging up --build

# staging ≠ production validators: APP_ENV=staging does not enforce prod secret rules.
# Use production-like settings anyway so surprises show up before prod.
APP_ENV=staging
APP_DEBUG=false
APP_NAME=CineTaste Staging
API_PREFIX=/api/v1

# Staging SPA origin (Vercel preview or dedicated staging URL)
CORS_ORIGINS=http://localhost:5173,https://cinetaste-staging.vercel.app

# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=staging-only-change-me-to-a-long-random-string-at-least-32
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=14
JWT_ALGORITHM=HS256

POSTGRES_USER=cinetaste
POSTGRES_PASSWORD=staging-change-me
POSTGRES_DB=cinetaste_staging

# Host ports (compose maps these; avoid clashing with local 5432/6379/8000)
STAGING_API_PORT=8001
STAGING_DB_PORT=5433
STAGING_REDIS_PORT=6380

# Overridden inside compose for the api service; keep for tools/docs
DATABASE_URL=postgresql+asyncpg://cinetaste:staging-change-me@localhost:5433/cinetaste_staging
REDIS_URL=redis://localhost:6380/0

TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
WATCH_PROVIDER_REGION=US
WATCH_PROVIDER_CACHE_TTL_SECONDS=43200

REC_SLATE_SIZE=20
REC_CACHE_TTL_SECONDS=300
REC_MMR_LAMBDA=0.7
REC_EXPLORATION_SLOTS=3
REC_LOG_IMPRESSIONS=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=30
RATE_LIMIT_AUTH_WINDOW_SECONDS=60

TRUSTED_HOSTS=
COOKIE_SECURE=false

WEB_CONCURRENCY=1
PORT=8000

PUBLIC_APP_URL=http://localhost:5173
PASSWORD_RESET_TTL_MINUTES=60

# Optional SMTP — leave empty for log-only reset tokens
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Optional separate Sentry project/env for staging
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_RELEASE=staging

# Frontend (Vercel Preview / staging project):
# VITE_API_BASE_URL=http://localhost:8001/api/v1
# or https://cinetaste-api-staging.onrender.com/api/v1
# VITE_SENTRY_DSN=
